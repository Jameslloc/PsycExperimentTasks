        <Param val="True" valType="bool" updates="None" name="syncScreenRefresh"/>
        <Param val="Well done so far.&amp;#10;&amp;#10;In the next task, you will be given a category, and you must type as many items from that category as you can. &amp;#10;&amp;#10;For instance, if the category is &quot;words beginning with F&quot; you should type as many words that begin with F as you can." valType="str" updates="constant" name="text"/>
        <Param val="from exp settings" valType="str" updates="None" name="units"/>
        <Param val="1.2" valType="code" updates="constant" name="wrapWidth"/>
      </TextComponent>
