        <Param val="&amp;#10;EscapeAllowed = True&amp;#10;win.mouseVisible = False&amp;#10;&amp;#10;# set duration of each trial&amp;#10;VFtime=60&amp;#10;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Both" valType="str" updates="None" name="Code Type"/>
        <Param val="" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="document.body.style.cursor='none';" valType="extendedCode" updates="constant" name="Each JS Frame"/>
