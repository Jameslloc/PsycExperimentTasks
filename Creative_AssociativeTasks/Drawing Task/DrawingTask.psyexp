    <LoopInitiator loopType="TrialHandler" name="trials_draw">
      <Param name="Selected rows" updates="None" val="" valType="str"/>
      <Param name="conditions" updates="None" val="[OrderedDict([('DrawStim', 26)]), OrderedDict([('DrawStim', 13)]), OrderedDict([('DrawStim', 9)]), OrderedDict([('DrawStim', 3)]), OrderedDict([('DrawStim', 5)]), OrderedDict([('DrawStim', 28)]), OrderedDict([('DrawStim', 23)]), OrderedDict([('DrawStim', 4)]), OrderedDict([('DrawStim', 16)]), OrderedDict([('DrawStim', 18)])]" valType="str"/>
      <Param name="conditionsFile" updates="None" val="DrawStims.xlsx" valType="str"/>
      <Param name="endPoints" updates="None" val="[0, 1]" valType="num"/>
      <Param name="isTrials" updates="None" val="True" valType="bool"/>
      <Param name="loopType" updates="None" val="random" valType="str"/>
      <Param name="nReps" updates="None" val="1" valType="code"/>
      <Param name="name" updates="None" val="trials_draw" valType="code"/>
      <Param name="random seed" updates="None" val="" valType="code"/>
    </LoopInitiator>
    <Routine name="cross"/>
    <Routine name="DrawingTrial"/>
    <LoopTerminator name="trials_draw"/>
  </Flow>
</PsychoPy2experiment>
